- stage: Validation
  displayName: "Validation & HTML Report"
  dependsOn: Deploy
  condition: succeeded()

  jobs:
  - job: Validation
    displayName: "Collect Kubernetes Logs"

    pool:
      name: sc-linux

    steps:

    - checkout: self

    - bash: |
        chmod +x scripts/k8-login.sh
        ./scripts/k8-login.sh
      displayName: "Kubernetes Login"

    - bash: |
        python3 scripts/verify.py
      displayName: "Verify Environment"

    - bash: |
        python3 scripts/collect_logs.py
      displayName: "Collect Kubernetes Logs"

    - bash: |
        python3 scripts/report.py
      displayName: "Generate HTML Report"

    - publish: reports
      artifact: ValidationReport
      displayName: "Publish HTML Report"
