import os
from datetime import datetime


def generate_report(results):

    os.makedirs("reports", exist_ok=True)

    passed = len([r for r in results if r["result"] == "PASS"])

    failed = len(results) - passed

    report_name = "reports/SanityReport_" + datetime.now().strftime("%Y%m%d_%H%M%S") + ".html"

    html = f"""

<html>

<head>

<title>Production Sanity Report</title>

<style>

body{{font-family:Arial;background:#f5f5f5;padding:20px;}}

table{{border-collapse:collapse;width:100%;margin-top:20px;}}

th{{background:#0B5394;color:white;padding:10px;}}

td{{padding:8px;border:1px solid #ddd;}}

.pass{{background:#C8E6C9;}}

.fail{{background:#FFCDD2;}}

.details{{

margin-top:25px;

padding:15px;

background:white;

border-radius:6px;

box-shadow:0px 2px 5px gray;

}}

pre{{

background:#efefef;

padding:10px;

overflow:auto;

}}

</style>

</head>

<body>

<h1>Production Sanity Report</h1>

<hr>

<h3>Total Scenarios : {len(results)}</h3>

<h3 style="color:green;">Passed : {passed}</h3>

<h3 style="color:red;">Failed : {failed}</h3>

<hr>

<table>

<tr>

<th>Namespace</th>

<th>Service</th>

<th>Scenario</th>

<th>Validation</th>

<th>HTTP Status</th>

<th>Response Validation</th>

<th>Execution Time(ms)</th>

<th>Result</th>

</tr>

"""

    for r in results:

        colour = "pass"

        if r["result"] == "FAIL":

            colour = "fail"

        html += f"""

<tr class="{colour}">

<td>{r['namespace']}</td>

<td>{r['service']}</td>

<td>{r['scenario']}</td>

<td>{r['validation']}</td>

<td>{r['httpStatus']}</td>

<td>{r['responseValidation']}</td>

<td>{r['executionTime']}</td>

<td>{r['result']}</td>

</tr>

"""

    html += "</table>"

    html += "<br><hr><h2>Scenario Details</h2>"

    for r in results:

        html += f"""

<div class="details">

<h3>{r['scenario']}</h3>

<b>Namespace :</b> {r['namespace']}<br>

<b>Service :</b> {r['service']}<br>

<b>Endpoint :</b> {r['endpoint']}<br>

<b>HTTP Status :</b> {r['httpStatus']}<br>

<b>Execution :</b> {r['executionTime']} ms<br>

<b>Validation :</b> {r['validation']}<br>

<b>Result :</b> {r['result']}<br>

<h4>Validation Errors</h4>

<pre>{"<br>".join(r['validationErrors']) if r['validationErrors'] else "None"}</pre>

<h4>Payload</h4>

<pre>{r['payload']}</pre>

<h4>Response</h4>

<pre>{r['response']}</pre>

</div>

"""

    html += "</body></html>"

    with open(report_name, "w", encoding="utf-8") as f:

        f.write(html)

    return report_name
