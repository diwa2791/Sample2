import json
import time
import urllib.request
import urllib.error


def send_request(service_config, payload):

    url = f"http://localhost:{service_config['port']}{service_config['endpoint']}"

    data = json.dumps(payload).encode("utf-8")

    headers = service_config.get("headers", {})

    method = service_config.get("method", "POST")

    request = urllib.request.Request(
        url=url,
        data=data,
        headers=headers,
        method=method
    )

    start = time.time()

    try:

        with urllib.request.urlopen(request, timeout=30) as response:

            end = time.time()

            return {

                "success": True,

                "status": response.status,

                "response": response.read().decode("utf-8"),

                "executionTime": round((end-start)*1000,2)

            }

    except urllib.error.HTTPError as e:

        end = time.time()

        return {

            "success": False,

            "status": e.code,

            "response": e.read().decode("utf-8"),

            "executionTime": round((end-start)*1000,2)

        }

    except Exception as e:

        end = time.time()

        return {

            "success": False,

            "status": 0,

            "response": str(e),

            "executionTime": round((end-start)*1000,2)

        }
